# VPN server URL or IP
server=vpn.tuwien.ac.at

# Defines the method for 2FA
useragent=AnyConnect

# Username for authentication
user=gbellomi@tuwien.ac.at

# Choice for the silly TUnet gate
authgroup=2_Alles_getunnelt
# 1_TU_getunnelt    # Only TU services are passed through
# 2_Alles_getunnelt # The whole traffic is passed through

# (OpenConnect will prompt interactively if omitted)
passwd-on-stdin

# To avoid getting a webvpn request for the TOTP
# and just have it ask for the TOTP after the PWD
no-external-auth

# Use a specific certificate for authentication
# (uncomment if needed)
# certificate=/path/to/cert.pem
# private-key=/path/to/key.pem

# Disable DTLS if your server has issues with it
# (DTLS improves performance but some gateways misbehave)
# no-dtls

# Automatically reconnect if the tunnel drops
reconnect-timeout=30

# Set a custom MTU if needed
# mtu=1400

# Extra arguments passed directly to OpenConnect
# (e.g., to accept invalid certs — not recommended)
# script-tun
# no-cert-check
